    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "{ \n\"response_type\": \"ephemeral\", \"text\": \"⏳ Processing your request...\" \n}",
        "options": {}
      },
      "type": "n8n-nodes-base.respondToWebhook",
