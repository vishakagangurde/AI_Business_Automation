      "id": "7d213185-08b9-40f4-a713-6f0738f5888f",
      "name": "Instant Slack Acknowledgement"
    },
    {
      "parameters": {
        "jsCode": "// Safe body parsing — handles both string and object\nconst rawInput = $input.item.json;\nconst body = typeof rawInput.body === 'string' \n  ? JSON.parse(rawInput.body) \n  : (rawInput.body || rawInput);\n\n// Sanitize: prevent spreadsheet formula injection\nconst rawText = (body.text || '').trim();\nconst sanitizedText = rawText.replace(/^[=+\\-@]/, \"'$&\");\n\n// Idempotency key\nconst idempotencyKey = `${body.user_id || 'unknown'}-${body.command || 'task'}-${body.trigger_id || Date.now()}`;\n\n// Parse due date from natural language\nfunction parseDueDate(text) {\n  const lower = text.toLowerCase();\n  const now = new Date();\n  if (lower.includes('tomorrow')) {\n    now.setDate(now.getDate() + 1);\n    return now.toISOString().split('T')[0];\n  }\n  if (lower.includes('today')) {\n    return now.toISOString().split('T')[0];\n  }\n  const days = ['sunday','monday','tuesday','wednesday','thursday','friday','saturday'];\n  for (let i = 0; i < days.length; i++) {\n    if (lower.includes(days[i])) {\n      const target = i;\n      const current = now.getDay();\n      const diff = (target - current + 7) % 7 || 7;\n      now.setDate(now.getDate() + diff);\n      return now.toISOString().split('T')[0];\n    }\n  }\n  return null;\n}\n\nconst dueDate = parseDueDate(sanitizedText);\n\nconst cleanText = sanitizedText\n  .replace(/\\b(today|tomorrow|monday|tuesday|wednesday|thursday|friday|saturday|sunday)\\b/gi, '')\n  .replace(/\\s{2,}/g, ' ')\n  .trim();\n\n// Guard: ensure cleanText is a non-empty string\nconst finalText = cleanText.length > 0 ? cleanText : rawText;\n\nreturn [{\n  json: {\n    text: String(finalText),\n    raw_text: String(rawText),\n    user_name: String(body.user_name || ''),\n    user_id: String(body.user_id || ''),\n    channel_id: String(body.channel_id || ''),\n    command: String(body.command || '/task'),\n    due_date: dueDate ? String(dueDate) : null,\n    idempotency_key: String(idempotencyKey),\n    timestamp: new Date().toISOString(),\n    status: 'pending'\n  }\n}];"
      },
